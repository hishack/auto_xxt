{
  "manifest_version": 3,
  "name": "学习通题目提取器",
  "version": "1.0.0",
  "description": "从超星学习通网页中提取题目，支持字体解密",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.chaoxing.com/*",
    "*://*.mooc.chaoxing.com/*",
    "*://*.chaoxing.com.cn/*",
    "https://116611.xyz/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chaoxing.com/*",
        "*://*.mooc.chaoxing.com/*",
        "*://*.chaoxing.com.cn/*",
        "*://passport2.chaoxing.com/*",
        "*://mooc1.chaoxing.com/*",
        "*://mooc2.chaoxing.com/*",
        "*://i.chaoxing.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
